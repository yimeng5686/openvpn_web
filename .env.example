# ============================================================
# OpenVPN Web 管理系统 - 环境变量配置文件
# 使用方法：复制此文件为 .env，然后修改其中的值
#   copy .env.example .env
# 优先级：系统环境变量 > .env 文件 > config.py 中的默认值
# ============================================================

# ==================== Flask 配置 ====================
# Session 加密密钥（生产环境务必设置为强随机字符串）
# 可使用以下命令生成：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# ==================== OpenVPN 配置 ====================
# OpenVPN 服务器地址（用于生成客户端配置文件，必填）
OPENVPN_SERVER_IP=YOUR_SERVER_IP
# OpenVPN 服务器端口
OPENVPN_SERVER_PORT=1194
# OpenVPN 协议（udp / tcp）
OPENVPN_PROTOCOL=tcp
